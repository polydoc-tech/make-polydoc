{
  "name": "PolyDoc - Invoice PDF from template data",
  "flow": [
    {
      "id": 1,
      "module": "app#polydoc-vnm0g9:convertToPdf",
      "version": 1,
      "parameters": {},
      "mapper": {
        "sourceType": "template",
        "templateId": "YOUR_TEMPLATE_ID",
        "templateData": "{\n  \"invoice_number\": \"INV-001\",\n  \"invoice_date\": \"2026-01-31\",\n  \"customer_name\": \"Customer SARL\",\n  \"items\": [\n    { \"name\": \"Widget\", \"description\": \"Blue widget\", \"quantity\": 2, \"price\": 10 }\n  ]\n}",
        "format": "A4",
        "printBackground": true,
        "delivery": "download",
        "filename": "invoice.pdf"
      },
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "notes": "Replace YOUR_TEMPLATE_ID with a template saved in your PolyDoc dashboard, then map a record (Google Sheets row, webhook, DB query) into Template Data. Add a delivery module after this (Email, Google Drive, S3) to send the PDF."
      }
    }
  ],
  "metadata": {
    "instant": false,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] },
    "zone": "eu1.make.com"
  }
}
